{
  "name": "catalogo-miplace",
  "version": "1.1.0",
  "private": true,
  "description": "Catálogo digital Miplace Magazine — smartphones premium",
  "scripts": {
    "validate:products": "node scripts/validate-products.js",
    "test:snapshot": "node scripts/test-snapshot.js",
    "test": "node scripts/validate-products.js && node scripts/test-snapshot.js",
    "lint": "eslint app.js stores.js modules/ scripts/",
    "lint:fix": "eslint --fix app.js stores.js modules/ scripts/",
    "typecheck": "tsc -p jsconfig.json --noEmit",
    "build:css": "tailwindcss -i ./src/input.css -o ./tailwind.css --minify",
    "watch:css": "tailwindcss -i ./src/input.css -o ./tailwind.css --watch",
    "dev": "npm-run-all --parallel watch:css serve",
    "serve": "npx serve .",
    "build": "npm run validate:products && npm run lint:fix && npm run typecheck && npm run build:css"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "ajv": "^8.17.1",
    "eslint": "^9.13.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "serve": "^14.2.0"
  },
  "dependencies": {}
}
